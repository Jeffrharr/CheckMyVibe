{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CheckMyVibe coverage log entry",
  "description": "One line of CHECKMYVIBE_COVERAGE_LOG, as written by pr-interview's Review metrics section.",
  "type": "object",
  "required": ["date", "pr", "branch", "understanding_pct", "recommendation", "coverage", "robustness", "mind_changed"],
  "additionalProperties": false,
  "properties": {
    "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "pr": { "type": "integer", "minimum": 1 },
    "branch": { "type": "string", "minLength": 1 },
    "understanding_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
    "recommendation": { "type": "string", "minLength": 1 },
    "coverage": {
      "type": "object",
      "required": ["changed_lines_pct", "control_flow_pct", "functions_explained_pct", "dependencies_understood_pct"],
      "additionalProperties": false,
      "properties": {
        "changed_lines_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "control_flow_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "functions_explained_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "dependencies_understood_pct": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "skipped": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item", "expected"],
        "additionalProperties": false,
        "properties": {
          "item": { "type": "string", "minLength": 1 },
          "expected": { "type": "boolean" },
          "reason": { "type": "string" }
        }
      }
    },
    "robustness": {
      "type": "object",
      "required": ["objections_raised", "objections_resolved", "reviewer_changed_position", "unsupported_assumptions_remaining"],
      "additionalProperties": false,
      "properties": {
        "objections_raised": { "type": "integer", "minimum": 0 },
        "objections_resolved": { "type": "integer", "minimum": 0 },
        "reviewer_changed_position": { "type": "integer", "minimum": 0 },
        "unsupported_assumptions_remaining": { "type": "integer", "minimum": 0 }
      }
    },
    "mind_changed": { "type": "boolean" },
    "mind_changed_summary": {
      "type": "object",
      "required": ["what", "how", "why"],
      "additionalProperties": false,
      "properties": {
        "what": { "type": "string", "minLength": 1 },
        "how": { "type": "string", "minLength": 1 },
        "why": { "type": "string", "minLength": 1 }
      }
    },
    "engineer_surfaced_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["what", "how", "why"],
        "additionalProperties": false,
        "properties": {
          "what": { "type": "string", "minLength": 1 },
          "how": { "type": "string", "minLength": 1 },
          "why": { "type": "string", "minLength": 1 }
        }
      }
    },
    "ai_surfaced_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["what", "how", "why"],
        "additionalProperties": false,
        "properties": {
          "what": { "type": "string", "minLength": 1 },
          "how": { "type": "string", "minLength": 1 },
          "why": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
